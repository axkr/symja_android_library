<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<groupId>org.matheclipse</groupId>
	<artifactId>symja-distribution</artifactId>
	<version>3.2.0</version>
	<packaging>pom</packaging>

	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
	</properties>

	<dependencies>
		<dependency>
			<groupId>org.matheclipse</groupId>
			<artifactId>matheclipse-io</artifactId>
			<version>3.2.0</version>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>appassembler-maven-plugin</artifactId>
				<version>2.1.0</version>
				<executions>
					<execution>
						<id>assemble-app</id>
						<phase>package</phase>
						<goals>
							<goal>assemble</goal>
						</goals>
					</execution>
				</executions>
				<configuration>
					<repositoryLayout>flat</repositoryLayout>
					<assembleDirectory>${project.build.directory}/symja-app</assembleDirectory>
					<repositoryName>lib</repositoryName>
                    <useWildcardClassPath>true</useWildcardClassPath>
					<programs>
						<program>
							<mainClass>org.matheclipse.io.servlet.ServletServer</mainClass>
							<id>server</id>
							<jvmSettings>
								<initialMemorySize>512m</initialMemorySize>
								<maxMemorySize>2g</maxMemorySize>
								<extraArguments>
									<extraArgument>-XX:+UseG1GC</extraArgument>
									<extraArgument>-Dfile.encoding=UTF-8</extraArgument>
									<extraArgument>-XX:+UseStringDeduplication</extraArgument>
								</extraArguments>
							</jvmSettings>
						</program>

						<program>
							<mainClass>org.matheclipse.io.servlet.MMAServletServer</mainClass>
							<id>mmaserver</id>
							<jvmSettings>
								<initialMemorySize>512m</initialMemorySize>
								<maxMemorySize>2g</maxMemorySize>
								<extraArguments>
									<extraArgument>-XX:+UseG1GC</extraArgument>
									<extraArgument>-Dfile.encoding=UTF-8</extraArgument>
									<extraArgument>-XX:+UseStringDeduplication</extraArgument>
								</extraArguments>
							</jvmSettings>
						</program>

						<program>
							<mainClass>org.matheclipse.io.eval.Console</mainClass>
							<id>symja</id>
							<jvmSettings>
								<initialMemorySize>512m</initialMemorySize>
								<maxMemorySize>2g</maxMemorySize>
								<extraArguments>
									<extraArgument>-XX:+UseG1GC</extraArgument>
									<extraArgument>-Dfile.encoding=UTF-8</extraArgument>
									<extraArgument>-XX:+UseStringDeduplication</extraArgument>
								</extraArguments>
							</jvmSettings>
						</program>

						<program>
							<mainClass>org.matheclipse.io.eval.MMAConsole</mainClass>
							<id>mma</id>
							<jvmSettings>
								<initialMemorySize>512m</initialMemorySize>
								<maxMemorySize>2g</maxMemorySize>
								<extraArguments>
									<extraArgument>-XX:+UseG1GC</extraArgument>
									<extraArgument>-Dfile.encoding=UTF-8</extraArgument>
									<extraArgument>-XX:+UseStringDeduplication</extraArgument>
								</extraArguments>
							</jvmSettings>
						</program>
					</programs>
				</configuration>
			</plugin>

			<plugin>
				<groupId>org.jreleaser</groupId>
				<artifactId>jreleaser-maven-plugin</artifactId>
				<version>1.17.0</version>
				<configuration>
					<jreleaser>
						<project>
							<name>symja</name>
							<description>Java Computer Algebra System</description>
							<authors>
								<author>axkr</author>
							</authors>
							<license>GPL-3.0-or-later</license>
							<links>
								<homepage>https://github.com/axkr/symja_android_library</homepage>
							</links>
						</project>

						<assemble>
							<archive>
								<symja-archive>
									<active>ALWAYS</active>
									<formats>
										<format>ZIP</format>
										<format>TAR_GZ</format>
									</formats>
									<fileSets>
										<fileSet>
											<input>${project.build.directory}/symja-app</input>
											<output>symja-${project.version}</output>
										</fileSet>
									</fileSets>
								</symja-archive>
							</archive>
						</assemble>

						<distributions>
							<symja-distribution>
								<type>JAVA_BINARY</type>
								<artifacts>
									<artifact>
										<path>${project.build.directory}/jreleaser/assemble/symja-archive/archive/symja-${project.version}.zip</path>
									</artifact>
									<artifact>
										<path>${project.build.directory}/jreleaser/assemble/symja-archive/archive/symja-${project.version}.tar.gz</path>
									</artifact>
								</artifacts>
							</symja-distribution>
						</distributions>

						<release>
							<github>
								<owner>axkr</owner>
								<name>symja_android_library</name>
								<overwrite>true</overwrite>
								<changelog>
									<formatted>ALWAYS</formatted>
									<preset>conventional-commits</preset>
								</changelog>
							</github>
						</release>
					</jreleaser>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>